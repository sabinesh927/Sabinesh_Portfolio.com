# SABINESH AGENT Chatbot API
# Set this to your LLM backend endpoint URL
# The endpoint should accept POST requests with { messages: [{role, content}] }
# and return { response: "..." }
VITE_CHATBOT_API_URL=your_api_url_here

# Examples:
# VITE_CHATBOT_API_URL=http://localhost:8000/chat
# VITE_CHATBOT_API_URL=https://your-langchain-api.com/chat
# VITE_CHATBOT_API_URL=https://api.openai.com/v1/chat/completions
